FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=sua_chave_secreta_aqui_troque_em_producao

# DATABASE - Escolha uma:
# Para desenvolvimento (SQLite):
DATABASE_URL=sqlite:///dev.db

# Para produção (PostgreSQL no Render):
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Para produção (PostgreSQL no Supabase):
# DATABASE_URL=postgresql://[USER]:[PASSWORD]@[HOST]/[NAME]?sslmode=require

# Google Analytics
GA_MEASUREMENT_ID=

# Email (Opcional)
MAIL_USERNAME=seu_email@exemplo.com
MAIL_PASSWORD=sua_senha_de_aplicativo_ou_senha_real

